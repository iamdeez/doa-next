# scripts/migration/config.example.env — 020-data-migration-cutover 러너 접속 설정 템플릿 (T006)
#
# 사용법: 이 파일을 config.env 로 복사한 뒤 실값을 채운다.
#   cp scripts/migration/config.example.env scripts/migration/config.env
# config.env 는 자격증명을 포함하므로 **절대 커밋하지 않는다**(.gitignore 에 scripts/migration/config.env
# 추가 필요 — 러너 실행 전 확인). 값은 flyctl secrets / 운영 시크릿 저장소에서 실행 시점에 주입한다.
#
# 평문 로그 금지(ADR-009/NFR-006): extract.sh·load.sh·run.sh 는 DSN 을 로그에 남길 때 반드시
# mask_dsn(lib/common.sh)으로 자격증명을 마스킹한다. 이 파일 자체를 로그·리포트에 붙여넣지 않는다.

# ------------------------------------------------------------
# TLS(ADR-009, FR-015/NFR-004, SC-017) — 모든 psql 접속 공통 강제
# ------------------------------------------------------------
export PGSSLMODE=require

# ------------------------------------------------------------
# 타깃(Fly Postgres) 접속
# ------------------------------------------------------------
# flyctl secrets 로 주입된 값을 참조하거나(`fly ssh console` 상 환경변수), 로컬에서는
# `fly proxy 5433:5432` 로 터널링 후 localhost 로 접속한다. sslmode=require 는 위 PGSSLMODE 로 강제되므로
# DSN 문자열에 중복 표기하지 않아도 되나, 명시적으로 남겨도 무방하다.
export TARGET_DSN="postgresql://<user>@<target-host>:5432/<db>?sslmode=require"

# ------------------------------------------------------------
# 레거시 접속 — 서비스별 개별 RDS(FR-001). 한 번에 하나의 서비스만 대상으로 실행하며,
# 이관 대상 서비스를 바꿀 때마다 아래 두 값을 교체하여 재실행한다(extract.sh --service 필터와 일치시킬 것).
# ------------------------------------------------------------
export LEGACY_DSN="postgresql://<user>@<legacy-host>:5432/<db>?sslmode=require"
export LEGACY_SERVICE="[TO-VERIFY: 예 — auth-service. delta-classes.conf 의 legacy_service 열과 일치해야 함]"

# ------------------------------------------------------------
# 결제 outbox 드레인 확인(ADR-008, run.sh 단계 0b) — 선택. 미설정 시 run.sh 가 수동 확인을 요구한다.
# 레거시 payment_outbox 의 실제 컬럼명은 [TO-VERIFY].
# ------------------------------------------------------------
export LEGACY_OUTBOX_PENDING_QUERY="[TO-VERIFY: 예 — SELECT count(*) FROM payment_outbox WHERE status = 'pending']"

# ------------------------------------------------------------
# 레거시 쓰기 차단/해제 자동화 명령(ADR-003, run.sh 단계 1/6) — 선택.
# 비워두면 run.sh 가 수동 확인(사용자 y/N 입력)을 요구한다. 앱 점검모드 503 은 레거시 앱의 책임이며
# 본 러너(신규 시스템 out-of-band 도구) 가 대신 수행하지 않는다 — 별도로 병행 실시할 것.
# ------------------------------------------------------------
export LEGACY_WRITE_BLOCK_CMD=""
export LEGACY_WRITE_UNBLOCK_CMD=""

# ------------------------------------------------------------
# 트래픽 전환 후 smoke 확인(S2 단계 5)
# ------------------------------------------------------------
export TARGET_HEALTH_URL="https://<fly-app>.fly.dev/health"

# ------------------------------------------------------------
# 로그·중간 산출물 디렉토리(Fly one-off machine 로컬 디스크 또는 마운트 볼륨)
# ------------------------------------------------------------
export MIGRATION_OUT_DIR="./migration-run"
export MIGRATION_LOG_FILE="./migration-run/migration.log"

# ------------------------------------------------------------
# 022-legacy-file-binary-migration — 레거시 오브젝트 스토리지(S3 호환) 접속(files-migrate.sh).
# 정확한 버킷명·엔드포인트·리전은 [TO-VERIFY](레거시 실 구조 미상, 옵션 A — 사용자 실측 후 채움).
# 전송 채널은 반드시 https:// 를 사용한다(NFR-004/ADR-009) — TLS 미적용 평문 엔드포인트 금지.
# ------------------------------------------------------------
export LEGACY_S3_ENDPOINT="[TO-VERIFY: 예 — https://s3.ap-northeast-2.amazonaws.com]"
export LEGACY_S3_REGION="[TO-VERIFY: 예 — ap-northeast-2]"
export LEGACY_S3_BUCKET="[TO-VERIFY: 레거시 버킷명]"
export LEGACY_S3_ACCESS_KEY_ID="<legacy-s3-read-only-access-key-id>"
export LEGACY_S3_SECRET_ACCESS_KEY="<legacy-s3-read-only-secret-access-key>"

# ------------------------------------------------------------
# 022-legacy-file-binary-migration — Cloudflare R2 접속(files-migrate.sh, 021 R2_* 재사용).
# R2 엔드포인트는 R2_ACCOUNT_ID 로 스크립트가 자동 구성한다(https://<account-id>.r2.cloudflarestorage.com,
# 항상 TLS — NFR-004). R2_PUBLIC_BASE_URL 은 files.files.url 갱신 base(021 이미 도입, FR-004).
#
# 보안 권장(Security Agent 검토 대상): 021 이 발급한 R2 자격증명(앱 런타임 presign 발급용)과
# 별도로, 이관 전용 write-scoped 토큰(레거시→R2 복사에 필요한 PutObject 권한만 부여)을 분리
# 발급하는 것을 권장한다 — 이관 완료 후 폐기가 용이하고 앱 런타임 자격증명과 blast radius 를
# 분리할 수 있다.
# ------------------------------------------------------------
export R2_ACCOUNT_ID="<r2-account-id>"
export R2_ACCESS_KEY_ID="<r2-migration-write-scoped-access-key-id>"
export R2_SECRET_ACCESS_KEY="<r2-migration-write-scoped-secret-access-key>"
export R2_BUCKET="<r2-bucket-name>"
export R2_PUBLIC_BASE_URL="https://pub-xxxx.r2.dev"

# ------------------------------------------------------------
# rclone 전송 파라미터(선택 — 미설정 시 files-migrate.sh 기본값 사용: retries=3, transfers=8)
# ------------------------------------------------------------
export RCLONE_RETRIES="3"
export RCLONE_RETRIES_SLEEP="10s"
export RCLONE_TRANSFERS="8"
