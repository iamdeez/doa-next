DATABASE_URL=postgresql://user:password@localhost:5432/doa_next
JWT_ACCESS_SECRET=your-access-secret-here
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_REFRESH_TTL=30d
NODE_ENV=development
PORT=3000
# 콤마구분 CORS 허용 origin 목록(예: https://console.doa.market,https://app.doa.market).
# 미설정 시 전체 허용(true) — 로컬/개발 편의. 운영에서는 반드시 화이트리스트를 설정한다(fail-open 주의).
CORS_ORIGIN=
# 콤마구분 admin user id 목록. 미설정 시 approve/reject 전면 차단(fail-closed).
ADMIN_USER_IDS=

# SMTP 이메일 전송 설정 (NODE_ENV=production 시 StubMailer → SmtpMailer 로 전환)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password
MAIL_FROM=noreply@doa.market

# 소셜 로그인 크레덴셜 (ADR-007)
# 카카오: REST API 키 (카카오 개발자 콘솔 → 앱 설정 → 앱 키)
KAKAO_REST_API_KEY=your-kakao-rest-api-key
# 카카오: 앱 ID (카카오 개발자 콘솔 → 앱 설정 → 앱 키 하단 "앱 ID" — REST API 키와는 다른 값).
# access_token_info 응답의 app_id 와 대조하여 타 앱이 발급한 토큰을 거부한다 (SEC-001).
KAKAO_APP_ID=your-kakao-app-id
# 구글: OAuth 2.0 클라이언트 ID (GCP 콘솔 → API 및 서비스 → 사용자 인증 정보)
GOOGLE_CLIENT_ID=your-google-client-id
# 네이버: 애플리케이션 클라이언트 ID (네이버 개발자 센터)
NAVER_CLIENT_ID=your-naver-client-id
# 네이버: 애플리케이션 클라이언트 시크릿
NAVER_CLIENT_SECRET=your-naver-client-secret
# 네이버: 토큰 교환 redirect_uri (선택 — 네이버가 요구할 경우에만 설정. 미설정 시 미포함이 기본)
NAVER_REDIRECT_URI=

# 결제/파일 Port 구현체 선택 (021-payment-file-integration, ADR-005)
# 미설정·미인식 값은 안전하게 stub 로 부팅(크레덴셜 부재 시에도 앱 기동 유지).
# 결제: inicis|stub (기본 stub). 파일: r2|stub (기본 stub).
PAYMENT_PROVIDER=stub
FILE_STORAGE=stub

# KG이니시스 결제 게이트웨이 크레덴셜 (PAYMENT_PROVIDER=inicis 선택 시에만 필수)
# [TO-VERIFY] 정확한 키명·발급 위치는 이니시스 개발자센터 공식 문서로 확정 필요(GAP-021-02).
# 공용 테스트 상점ID(sandbox MID)는 이니시스 개발자센터 가입 후 확인.
INICIS_MID=your-inicis-mid
INICIS_SIGN_KEY=your-inicis-sign-key
# [TO-VERIFY] sandbox/prod 엔드포인트 URL — 추측 값 미기재, 이니시스 개발자센터 문서로 확정
INICIS_API_BASE_URL=your-inicis-api-base-url
INICIS_API_KEY=your-inicis-api-key
INICIS_API_IV=your-inicis-api-iv

# Cloudflare R2 (021-payment-file-integration, ADR-001)
# FILE_STORAGE=r2 선택 시에만 필수. 공개 URL 은 r2.dev 서브도메인만 사용(커스텀 도메인 범위 외).
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-r2-bucket-name
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
